# Graph MCP Server Environment Configuration

# Azure AD Configuration
AZURE_AD_TENANT_ID=your-tenant-id
AZURE_AD_CLIENT_ID=your-client-id
AZURE_AD_INSTANCE=https://login.microsoftonline.com/your-tenant-id

# Client Credential (use Federated Identity Credential in production)
# This is only needed for local testing
AZURE_AD_CLIENT_SECRET=your-client-secret

# Optional: Application Insights for telemetry
APPLICATIONINSIGHTS_CONNECTION_STRING=
